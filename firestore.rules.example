rules_version = '2';
// Copy into Firebase Console → Firestore → Rules (or use Firebase CLI deploy).
// Enables navbar user search (reads user docs) and follower subcollections.

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == followerId;
      }

      match /notifications/{notificationId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == notificationId
          && request.auth.uid != userId
          && request.resource.data.type == 'follow'
          && request.resource.data.fromUid == notificationId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && (
          request.auth.uid == userId || request.auth.uid == notificationId
        );
      }
    }
  }
}
