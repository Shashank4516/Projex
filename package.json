{
  "name": "projex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k --names \"spring,vite\" -c \"magenta,cyan\" \"npm run dev:api\" \"wait-on -t 180000 -i 250 tcp:127.0.0.1:3001 && npm run dev:vite\"",
    "dev:vite": "vite",
    "dev:api": "./backend/gradlew -p backend bootRun",
    "dev:api:node": "node server/index.mjs",
    "dev:vite-only": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "firebase": "^12.13.0",
    "pg": "^8.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^14.24.0",
    "globals": "^17.5.0",
    "vite": "^8.0.10",
    "wait-on": "^9.0.10"
  }
}
