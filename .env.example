# Railway Postgres (Dashboard → Variables → DATABASE_URL, or paste connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# API server port (optional; default 3001)
# API_PORT=3001

# Set to false only if your DB does not use TLS
# DATABASE_SSL=true

# Firebase Console → Authentication → Settings → Authorized domains:
# add localhost (and your production host) so Google sign-in redirect returns correctly.
